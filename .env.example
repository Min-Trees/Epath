# GROQ API Key (for AI chatbot features)
GROQ_API_KEY=

# Google Sheets - lưu lead từ chatbot tư vấn
# 1. Tạo Google Cloud project + Service Account
# 2. Share Google Sheet với email của Service Account (quyền Editor)
# 3. Paste các giá trị dưới đây:
GOOGLE_SHEETS_ID=your_spreadsheet_id_from_the_url
# Tên tab trong Google Sheet (mặc định "Sheet1"). Bỏ trống nếu dùng mặc định.
GOOGLE_SHEETS_TAB=Sheet1
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Private key dạng PEM. Toàn bộ nội dung trong ngoặc kép, bao gồm cả \n ở đầu/cuối.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Zalo Bot - gửi thông báo lead mới đến tài khoản Zalo cố định
# 1. Tạo bot qua OA "Zalo Bot Manager" -> nhận token dạng "bot_id:secret_key"
# 2. Mở Zalo trên điện thoại, tìm và nhắn tin cho bot trước
# 3. Truy cập /api/chatbot/zalo-test?action=updates để lấy chat_id của bạn
# 4. Paste chat_id vào ZALO_BOT_CHAT_ID bên dưới
# 5. Test bằng /api/chatbot/zalo-test?action=send
ZALO_BOT_TOKEN=1563480220908407300:your_secret_key_here
ZALO_BOT_CHAT_ID=
